# PostgreSQL (servicio "db" en docker-compose)
POSTGRES_DB=angwood
POSTGRES_USER=angwood_user
POSTGRES_PASSWORD=cambia_esta_contraseña

# Conexión de la API a la base de datos
# En Docker usa el hostname "db" (nombre del servicio en docker-compose)
DATABASE_URL=postgresql://angwood_user:cambia_esta_contraseña@db:5432/angwood

# JWT / autenticación
SECRET_KEY=genera_una_clave_larga_y_aleatoria_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Usuario administrador inicial (se crea al arrancar con create_admin_user)
SUPERUSER_USERNAME=admin
EMAIL=admin@example.com
PASSWORD=cambia_esta_contraseña_admin

GOOGLE_API_KEY=placeholder-local
GEMINI_API_KEY=placeholder-local

# Mercado Pago Checkout Pro
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
MP_WEBHOOK_SECRET=cambia_este_secreto_aleatorio